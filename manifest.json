{
  "manifest_version": 2,
  "name": "Video Downloader",
  "version": "1.1.0",
  "description": "현재 탭의 비디오를 자동 감지하고 다운로드합니다. TikTok 작성자/캡션 자동 추출 지원.",
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "downloads",
    "activeTab",
    "tabs",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  }
}
